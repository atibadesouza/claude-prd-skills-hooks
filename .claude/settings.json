{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/prd-reminder.mjs",
            "timeout": 5,
            "statusMessage": "Checking PRD maintenance..."
          },
          {
            "type": "command",
            "command": "node .claude/hooks/post-commit-pitfalls.mjs",
            "timeout": 5,
            "statusMessage": "Checking commit for pitfalls scan..."
          }
        ]
      },
      {
        "matcher": "ExitPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/save-plan.mjs",
            "timeout": 5,
            "statusMessage": "Saving plan to docs/plans/..."
          }
        ]
      }
    ]
  }
}
